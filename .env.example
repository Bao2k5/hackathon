# LLM Provider — AI/ML API (Prize track: best use of AI/ML API = $1000)
OPENAI_API_KEY=your_aimlapi_key_here
OPENAI_BASE_URL=https://api.aimlapi.com/v1
MODEL_NAME=gpt-4o-mini

# Band.ai
BAND_ROOM_ID=your_band_room_id_here
BAND_BOT_TOKEN=your_band_bot_token_here

# Sponsor Prize: Featherless AI (Top 3 prize track: $500, $300, $100)
# Fill this in to route Policy Checker to Qwen on Featherless serverless provider.
# Leave blank to fallback automatically to AI/ML API.
FEATHERLESS_API_KEY=your_featherless_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

# PostgreSQL (Docker only)
POSTGRES_PASSWORD=changeme123

